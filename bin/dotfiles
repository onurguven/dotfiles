#!/usr/bin/env bash

# Dotfiles Management Script
# ==========================
# Usage: dotfiles [command]

set -euo pipefail

DOTFILES_DIR="${HOME}/dotfiles"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

show_help() {
    echo "Dotfiles Management"
    echo ""
    echo "Usage: dotfiles [command]"
    echo ""
    echo "Commands:"
    echo "  update    - Pull latest changes and reinstall"
    echo "  edit      - Open dotfiles in editor"
    echo "  cd        - Change to dotfiles directory"
    echo "  backup    - Create backup of current configs"
    echo "  restore   - List available backups"
    echo "  status    - Show git status"
    echo "  help      - Show this help message"
}

case "${1:-help}" in
    update)
        echo -e "${YELLOW}Updating dotfiles...${NC}"
        cd "$DOTFILES_DIR"
        git pull origin "$(git branch --show-current)"
        git submodule update --init --recursive
        make core
        echo -e "${GREEN}Done!${NC}"
        ;;
    edit)
        ${EDITOR:-code} "$DOTFILES_DIR"
        ;;
    cd)
        echo "$DOTFILES_DIR"
        ;;
    backup)
        echo -e "${YELLOW}Creating backup...${NC}"
        BACKUP_DIR="${HOME}/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"
        mkdir -p "$BACKUP_DIR"
        for file in .zshrc .zshenv .gitconfig .gitignore_global; do
            [[ -f "${HOME}/${file}" ]] && cp "${HOME}/${file}" "$BACKUP_DIR/"
        done
        [[ -d "${HOME}/.ssh" ]] && cp -r "${HOME}/.ssh" "$BACKUP_DIR/"
        echo -e "${GREEN}Backup created at: $BACKUP_DIR${NC}"
        ;;
    restore)
        echo "Available backups:"
        ls -la "${HOME}/.dotfiles-backup/" 2>/dev/null || echo "No backups found"
        echo ""
        echo "To restore: cp -r ~/.dotfiles-backup/[DATE]/* ~/"
        ;;
    status)
        cd "$DOTFILES_DIR"
        git status
        ;;
    help|*)
        show_help
        ;;
esac
