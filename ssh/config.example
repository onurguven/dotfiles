# SSH Configuration
# ==================
# Copy this to ~/.ssh/config and customize
# Make sure permissions are correct: chmod 600 ~/.ssh/config

# ===================================
# Global defaults
# ===================================
Host *
    # Security
    IdentitiesOnly yes

    # Connection
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # macOS Keychain integration
    AddKeysToAgent yes
    UseKeychain yes

# ===================================
# GitHub - Personal
# ===================================
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519

# ===================================
# GitHub - Work (example)
# ===================================
# Host github-work
#     HostName github.com
#     User git
#     IdentityFile ~/.ssh/id_ed25519_work

# ===================================
# GitLab (example)
# ===================================
# Host gitlab.com
#     HostName gitlab.com
#     User git
#     IdentityFile ~/.ssh/id_ed25519

# ===================================
# Personal Servers (examples)
# ===================================
# Host myserver
#     HostName 192.168.1.100
#     User deploy
#     Port 22
#     IdentityFile ~/.ssh/id_ed25519

# Host prod
#     HostName production.example.com
#     User admin
#     Port 22
#     IdentityFile ~/.ssh/id_ed25519_prod
#     ForwardAgent no

# ===================================
# Jump Host / Bastion (example)
# ===================================
# Host bastion
#     HostName bastion.example.com
#     User admin
#     IdentityFile ~/.ssh/id_ed25519

# Host internal-server
#     HostName 10.0.0.10
#     User deploy
#     ProxyJump bastion
